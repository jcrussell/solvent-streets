<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>PVMT - Example Cities</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #0f0f23;
            color: #e0e0e0;
            min-height: 100vh;
        }
        header {
            background: #1a1a2e;
            padding: 24px 32px;
            border-bottom: 1px solid #2a2a4a;
        }
        header h1 { font-size: 24px; color: #fff; margin-bottom: 8px; }
        header p { color: #8888aa; font-size: 14px; max-width: 640px; line-height: 1.5; }
        main { max-width: 1200px; margin: 0 auto; padding: 32px; }
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
        }
        .card {
            background: #1a1a2e;
            border: 1px solid #2a2a4a;
            border-radius: 8px;
            padding: 20px;
            text-decoration: none;
            color: inherit;
            transition: border-color 0.15s, transform 0.15s;
        }
        .card:hover { border-color: #5555cc; transform: translateY(-2px); }
        .card h2 { font-size: 18px; color: #fff; margin-bottom: 8px; }
        .card .cities { color: #8888aa; font-size: 13px; margin-bottom: 12px; }
        .card .meta {
            display: flex;
            gap: 16px;
            font-size: 12px;
            color: #6666aa;
        }
        .card .meta span { white-space: nowrap; }
        footer {
            text-align: center;
            padding: 32px;
            color: #555;
            font-size: 12px;
        }
        footer a { color: #6666aa; text-decoration: none; }
        footer a:hover { text-decoration: underline; }

        :root {
            --meth-fg: #c8c8e0;
            --meth-heading: #fff;
            --meth-rule: #2a2a4a;
            --meth-code-bg: #22223e;
            --meth-code-fg: #9fb4ff;
            --meth-link: #8aa8ff;
            --meth-strong: #e8e8f8;
        }
        main .methodology { margin-top: 48px; }
    </style>
    {{template "methodology_styles" .}}
</head>
<body>
    <header>
        <h1>PVMT - Pavement Management Viewer</h1>
        <p>Interactive dashboards for pavement condition analysis and infrastructure cost forecasting across US cities. Each example below uses a different configuration to demonstrate various analysis scenarios.</p>
    </header>
    <main>
        <div class="grid">
            {{range .Examples}}
            <a class="card" href="./{{.Slug}}/">
                <h2>{{.Title}}</h2>
                <div class="cities">{{.CityNames}}</div>
                <div class="meta">
                    <span>{{.CityCount}} {{if eq .CityCount 1}}city{{else}}cities{{end}}</span>
                    <span>hex {{.HexEdgeM}}m</span>
                    <span>{{.UnitSystem}}</span>
                </div>
            </a>
            {{end}}
        </div>

        {{template "methodology" .MethodologyHTML}}
    </main>
    <footer>
        Generated by <a href="https://github.com/jcrussell/solvent-streets">pvmt</a>
    </footer>
</body>
</html>
