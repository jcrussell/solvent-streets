{{define "theme_boot"}}
<script>
(function(){
  try {
    var t = localStorage.getItem('pvmtTheme');
    if (!t) t = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    document.documentElement.dataset.theme = t;
  } catch(e) { document.documentElement.dataset.theme = 'light'; }
})();
</script>
{{end}}

