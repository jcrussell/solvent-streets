{{define "theme_toggle"}}
<script>
function toggleTheme(){
    var cur = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = cur;
    try { localStorage.setItem('pvmtTheme', cur); } catch(e) {}
    document.dispatchEvent(new CustomEvent('pvmt:themechange', {detail:{theme:cur}}));
    document.querySelectorAll('.theme-toggle').forEach(function(btn){
        btn.textContent = cur === 'dark' ? '\u2600' : '\u263E';
        btn.setAttribute('aria-checked', cur === 'dark' ? 'true' : 'false');
    });
}
document.querySelectorAll('.theme-toggle').forEach(function(btn){
    btn.textContent = document.documentElement.dataset.theme === 'dark' ? '\u2600' : '\u263E';
    btn.setAttribute('aria-checked', document.documentElement.dataset.theme === 'dark' ? 'true' : 'false');
});
</script>
{{end}}
