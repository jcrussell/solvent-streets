        <button class="theme-toggle" role="switch" aria-label="Toggle dark mode" onclick="toggleTheme()" style="{{if and (not .Cities) (not .IsLiveServer)}}margin-left:auto;{{end}}margin-right:16px;"></button>
    </div>

    <div id="map-tab" class="tab-content active" role="tabpanel" aria-labelledby="map-tab-btn">
