<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>PVMT - {{.ProjectName}}</title>
    <link rel="stylesheet" href="https://unpkg.com/maplibre-gl@4.1.2/dist/maplibre-gl.css">
    <script src="https://unpkg.com/maplibre-gl@4.1.2/dist/maplibre-gl.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
        #map { width: 100%; height: 100%; }
        .tab-bar {
            display: flex;
            background: #1a1a2e;
            padding: 0 16px;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            height: 48px;
        }
        .tab-bar h1 { color: #fff; font-size: 16px; line-height: 48px; margin-right: 32px; }
        .tab-btn {
            background: none;
            border: none;
            color: #8888aa;
            font-size: 14px;
            padding: 0 16px;
            cursor: pointer;
            line-height: 48px;
            border-bottom: 2px solid transparent;
        }
        .tab-btn.active { color: #fff; border-bottom-color: #3b82f6; }
        .tab-content { display: none; position: absolute; top: 48px; left: 0; right: 0; bottom: 0; z-index: 1; }
        .tab-content.active { display: block; }
        #map-tab { overflow: hidden; }
        #panel {
            position: absolute;
            top: 10px;
            right: 10px;
            background: rgba(255, 255, 255, 0.95);
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.15);
            max-width: 360px;
            font-size: 14px;
            z-index: 1;
            max-height: calc(100% - 20px);
            overflow-y: auto;
        }
        #panel h2 { font-size: 18px; margin-bottom: 4px; }
        #panel .subtitle { color: #666; margin-bottom: 16px; font-size: 12px; }
        .stat-card { background: #f9fafb; border-radius: 6px; padding: 12px; margin-bottom: 8px; }
        .stat-card h3 { font-size: 14px; text-transform: capitalize; margin-bottom: 8px; }
        .stat-row { display: flex; justify-content: space-between; padding: 2px 0; }
        .stat-label { color: #666; font-size: 13px; }
        .stat-value { font-weight: 600; font-size: 13px; }
        .layer-toggle { margin-top: 12px; border-top: 1px solid #eee; padding-top: 12px; }
        .layer-toggle label { display: flex; align-items: center; gap: 8px; cursor: pointer; padding: 4px 0; font-size: 13px; }
        .legend-dot { width: 12px; height: 12px; border-radius: 2px; display: inline-block; }
        .legend-gradient { width: 100px; height: 12px; border-radius: 2px; display: inline-block; }

        /* Color legend */
        #legend {
            position: absolute;
            bottom: 24px;
            right: 10px;
            background: rgba(255,255,255,0.92);
            padding: 10px 14px;
            border-radius: 6px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.15);
            z-index: 2;
            font-size: 12px;
        }
        #legend .legend-title { font-weight: 600; margin-bottom: 4px; }
        #legend .legend-bar {
            width: 180px; height: 12px; border-radius: 3px;
            background: linear-gradient(90deg, #f7fbff, #c6dbef, #6baed6, #2171b5, #08519c, #08306b);
        }
        #legend .legend-labels { display: flex; justify-content: space-between; margin-top: 2px; color: #666; }

        /* Hex tooltip */
        #hex-tooltip {
            position: absolute;
            pointer-events: none;
            z-index: 10;
            background: rgba(26,26,46,0.92);
            color: #fff;
            padding: 8px 12px;
            border-radius: 6px;
            font-size: 13px;
            line-height: 1.5;
            display: none;
            white-space: nowrap;
        }

        /* Hex detail panel */
        .hex-detail { font-size: 13px; }
        .hex-detail h3 { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
        .hex-detail .close-btn {
            background: none; border: none; font-size: 18px; cursor: pointer; color: #666; padding: 0 4px; line-height: 1;
        }
        .hex-detail table { width: 100%; border-collapse: collapse; }
        .hex-detail th, .hex-detail td { text-align: left; padding: 4px 6px; border-bottom: 1px solid #eee; }
        .hex-detail th { color: #666; font-weight: 500; }
        .hex-detail .total-row { font-weight: 600; border-top: 2px solid #ccc; }

        /* Financials tab */
        .financials { padding: 24px; max-width: 1200px; margin: 0 auto; overflow-y: auto; height: 100%; }
        .jurisdiction-toggle {
            display: flex;
            gap: 8px;
            margin-bottom: 20px;
        }
        .jurisdiction-toggle button {
            padding: 8px 20px;
            border: 1px solid #e5e7eb;
            border-radius: 6px;
            background: #fff;
            cursor: pointer;
            font-size: 14px;
            color: #666;
            transition: all 0.15s;
        }
        .jurisdiction-toggle button.active {
            background: #1a1a2e;
            color: #fff;
            border-color: #1a1a2e;
        }
        .scope-annotation {
            font-size: 13px;
            color: #666;
            margin-bottom: 16px;
            display: none;
        }
        .scope-annotation.visible { display: block; }
        .headlines { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; margin-bottom: 32px; }
        .headline-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 20px;
        }
        .headline-card .label { font-size: 13px; color: #666; margin-bottom: 4px; }
        .headline-card .value { font-size: 28px; font-weight: 700; color: #1a1a2e; }
        .headline-card .sub { font-size: 12px; color: #999; margin-top: 4px; }
        .chart-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(500px, 1fr)); gap: 24px; }
        .chart-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 20px;
        }
        .chart-card h3 { font-size: 15px; margin-bottom: 12px; color: #333; }
        .chart-card canvas { width: 100% !important; }
        .no-data { text-align: center; padding: 60px; color: #999; }
    </style>
</head>
<body>
    <div class="tab-bar">
        <h1>PVMT</h1>
        <button class="tab-btn active" data-tab="map-tab">Map</button>
        <button class="tab-btn" data-tab="financials-tab">Financials</button>
    </div>

    <div id="map-tab" class="tab-content active">
        <div id="map"></div>
        <div id="panel">
            <h2>{{.ProjectName}}</h2>
            <div class="subtitle">Pavement & Parking Analysis | {{.SnapshotDate}}</div>
            <div id="stats">
            {{range .Stats}}
                <div class="stat-card">
                    <h3>{{.Type}}</h3>
                    <div class="stat-row">
                        <span class="stat-label">Features</span>
                        <span class="stat-value" id="count-{{.Type}}">{{.FeatureCount}}</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">Area (acres)</span>
                        <span class="stat-value">{{printf "%.1f" .TotalAreaAcres}}</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">Area (sq mi)</span>
                        <span class="stat-value">{{printf "%.2f" (divf .TotalAreaAcres 640)}}</span>
                    </div>
                </div>
            {{end}}
            </div>
            <div class="layer-toggle" id="toggles"></div>
        </div>
        <div id="legend">
            <div class="legend-title">Coverage %</div>
            <div class="legend-bar"></div>
            <div class="legend-labels">
                <span>0%</span><span>25%</span><span>50%</span><span>75%</span><span>100%</span>
            </div>
        </div>
        <div id="hex-tooltip"></div>
    </div>

    <div id="financials-tab" class="tab-content">
        <div class="financials">
            <div class="jurisdiction-toggle" id="scope-toggle" style="display:none">
                <button class="active" data-scope="all">All Roads</button>
                <button data-scope="city">City Roads Only</button>
            </div>
            <div class="scope-annotation" id="scope-annotation"></div>
            <div class="headlines" id="headlines">
                <div class="no-data">Loading financial analysis...</div>
            </div>
            <div class="chart-grid" id="charts"></div>
        </div>
    </div>

    <script>
        // Tab switching
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
                btn.classList.add('active');
                document.getElementById(btn.dataset.tab).classList.add('active');
                if (btn.dataset.tab === 'map-tab' && window._map) window._map.resize();
            });
        });

        // Map
        const CENTER = [{{.CenterLon}}, {{.CenterLat}}];
        const layerColors = { {{range .Stats}}'{{.Type}}': '{{.Color}}', {{end}} };

        const map = new maplibregl.Map({
            container: 'map',
            style: {
                version: 8,
                sources: { 'osm': { type: 'raster', tiles: ['https://tile.openstreetmap.org/{z}/{x}/{y}.png'], tileSize: 256, attribution: '&copy; OpenStreetMap' } },
                layers: [{ id: 'osm', type: 'raster', source: 'osm', minzoom: 0, maxzoom: 19 }]
            },
            center: CENTER,
            zoom: 13
        });
        window._map = map;

        // Hex interactivity state
        let hexDataByType = {};   // { roads: [...features], parking: [...features] }
        let costSummary = {};     // { roads: {year1_cost, total_area_sqft}, ... }
        let activeTypes = new Set(Object.keys(layerColors));
        let savedPanelHTML = '';

        function fmtNum(n) {
            return Math.round(n).toLocaleString();
        }

        function fmtCost(n) {
            if (n >= 1e6) return '$' + (n/1e6).toFixed(1) + 'M';
            if (n >= 1e3) return '$' + (n/1e3).toFixed(0) + 'K';
            return '$' + Math.round(n).toLocaleString();
        }

        // Build blended hex FeatureCollection from active types
        function buildBlendedHexFC(hexDataByType, activeTypes, costSummary) {
            // Group all features by hex_id, only from active types
            const byHex = {};
            for (const type of activeTypes) {
                const features = hexDataByType[type] || [];
                for (const f of features) {
                    const hid = f.properties.hex_id;
                    if (!byHex[hid]) {
                        byHex[hid] = { geometry: f.geometry, area_sqft: 0, pct_covered: 0, est_cost: 0 };
                    }
                    byHex[hid].area_sqft += f.properties.area_sqft || 0;
                    byHex[hid].pct_covered += f.properties.pct_covered || 0;
                }
            }

            // Compute est_cost per hex
            for (const type of activeTypes) {
                const cs = costSummary[type];
                if (!cs || !cs.total_area_sqft) continue;
                const features = hexDataByType[type] || [];
                for (const f of features) {
                    const hid = f.properties.hex_id;
                    if (!byHex[hid]) continue;
                    byHex[hid].est_cost += ((f.properties.area_sqft || 0) / cs.total_area_sqft) * cs.year1_cost;
                }
            }

            const features = [];
            for (const [hid, data] of Object.entries(byHex)) {
                features.push({
                    type: 'Feature',
                    geometry: data.geometry,
                    properties: {
                        hex_id: hid,
                        area_sqft: data.area_sqft,
                        pct_covered: Math.min(data.pct_covered, 100),
                        est_cost: data.est_cost
                    }
                });
            }
            return { type: 'FeatureCollection', features };
        }

        function updateHexGrid() {
            const src = map.getSource('hexgrid');
            if (!src) return;
            const fc = buildBlendedHexFC(hexDataByType, activeTypes, costSummary);
            src.setData(fc);
        }

        map.on('load', async () => {
            let toggles = '';

            // Load resource layers
            for (const type of Object.keys(layerColors)) {
                try {
                    const resp = await fetch('data/' + type + '.geojson');
                    if (!resp.ok) continue;
                    const data = await resp.json();
                    map.addSource(type, { type: 'geojson', data });
                    map.addLayer({
                        id: type + '-fill', type: 'fill', source: type,
                        paint: { 'fill-color': layerColors[type], 'fill-opacity': 0.4, 'fill-outline-color': layerColors[type] }
                    });
                    toggles += '<label><input type="checkbox" checked data-layers="' + type + '-fill" data-type="' + type + '"><span class="legend-dot" style="background:' + layerColors[type] + '"></span>' + type + '</label>';
                } catch(e) {}
            }

            // Load hex cost summary
            try {
                const resp = await fetch('data/hex-cost-summary.json');
                if (resp.ok) costSummary = await resp.json();
            } catch(e) {}

            // Load hex grid
            try {
                const resp = await fetch('data/hexgrid.geojson');
                if (resp.ok) {
                    const data = await resp.json();
                    if (data.features && data.features.length > 0) {
                        // Parse into per-type buckets
                        for (const f of data.features) {
                            const rt = f.properties.resource_type || 'unknown';
                            if (!hexDataByType[rt]) hexDataByType[rt] = [];
                            hexDataByType[rt].push(f);
                        }

                        // Build initial blended FC
                        const blended = buildBlendedHexFC(hexDataByType, activeTypes, costSummary);

                        map.addSource('hexgrid', { type: 'geojson', data: blended });
                        map.addLayer({
                            id: 'hex-fill', type: 'fill', source: 'hexgrid',
                            paint: {
                                'fill-color': ['interpolate', ['linear'], ['get', 'pct_covered'],
                                    0, '#f7fbff', 10, '#c6dbef', 25, '#6baed6', 50, '#2171b5', 75, '#08519c', 100, '#08306b'],
                                'fill-opacity': 0.6
                            }
                        });
                        map.addLayer({
                            id: 'hex-outline', type: 'line', source: 'hexgrid',
                            paint: { 'line-color': '#333', 'line-width': 0.5, 'line-opacity': 0.3 }
                        });
                        toggles += '<label><input type="checkbox" checked data-layers="hex-fill,hex-outline"><span class="legend-gradient" style="background:linear-gradient(90deg,#c6dbef,#08306b)"></span>hex grid</label>';

                        // Hover tooltip
                        const tooltip = document.getElementById('hex-tooltip');
                        map.on('mousemove', 'hex-fill', e => {
                            map.getCanvas().style.cursor = 'pointer';
                            if (e.features && e.features.length > 0) {
                                const p = e.features[0].properties;
                                tooltip.innerHTML =
                                    '<strong>Coverage:</strong> ' + (p.pct_covered != null ? Math.round(p.pct_covered) : 0) + '%<br>' +
                                    '<strong>Area:</strong> ' + fmtNum(p.area_sqft || 0) + ' sq ft<br>' +
                                    '<strong>Est. Cost:</strong> ' + fmtCost(p.est_cost || 0);
                                tooltip.style.display = 'block';
                                tooltip.style.left = (e.point.x + 12) + 'px';
                                tooltip.style.top = (e.point.y - 12) + 'px';
                            }
                        });
                        map.on('mouseleave', 'hex-fill', () => {
                            map.getCanvas().style.cursor = '';
                            tooltip.style.display = 'none';
                        });

                        // Click detail panel
                        map.on('click', 'hex-fill', e => {
                            if (!e.features || e.features.length === 0) return;
                            const p = e.features[0].properties;
                            const hexId = p.hex_id;

                            // Save current stats panel
                            const statsEl = document.getElementById('stats');
                            if (!statsEl.querySelector('.hex-detail')) {
                                savedPanelHTML = statsEl.innerHTML;
                            }

                            // Build per-type breakdown
                            let rows = '';
                            let totalArea = 0, totalPct = 0, totalCost = 0;
                            for (const type of Object.keys(layerColors)) {
                                const features = hexDataByType[type] || [];
                                const match = features.find(f => f.properties.hex_id === hexId);
                                if (!match) continue;
                                const area = match.properties.area_sqft || 0;
                                const pct = match.properties.pct_covered || 0;
                                let cost = 0;
                                const cs = costSummary[type];
                                if (cs && cs.total_area_sqft) {
                                    cost = (area / cs.total_area_sqft) * cs.year1_cost;
                                }
                                totalArea += area;
                                totalPct += pct;
                                totalCost += cost;
                                rows += '<tr><td style="text-transform:capitalize">' + type + '</td><td>' + fmtNum(area) + '</td><td>' + Math.round(pct) + '%</td><td>' + fmtCost(cost) + '</td></tr>';
                            }

                            statsEl.innerHTML =
                                '<div class="hex-detail">' +
                                '<h3>Hex ' + hexId + '<button class="close-btn" id="close-hex">&times;</button></h3>' +
                                '<table><tr><th>Type</th><th>Area (sqft)</th><th>Coverage</th><th>Est. Cost</th></tr>' +
                                rows +
                                '<tr class="total-row"><td>Total</td><td>' + fmtNum(totalArea) + '</td><td>' + Math.min(Math.round(totalPct), 100) + '%</td><td>' + fmtCost(totalCost) + '</td></tr>' +
                                '</table></div>';

                            document.getElementById('close-hex').addEventListener('click', () => {
                                statsEl.innerHTML = savedPanelHTML;
                            });
                        });
                    }
                }
            } catch(e) {}

            document.getElementById('toggles').innerHTML = toggles;
            document.querySelectorAll('#toggles input').forEach(cb => {
                cb.addEventListener('change', e => {
                    const vis = e.target.checked ? 'visible' : 'none';
                    e.target.dataset.layers.split(',').forEach(id => map.setLayoutProperty(id, 'visibility', vis));

                    // Update activeTypes and reblend hex grid
                    const type = e.target.dataset.type;
                    if (type) {
                        if (e.target.checked) {
                            activeTypes.add(type);
                        } else {
                            activeTypes.delete(type);
                        }
                        updateHexGrid();
                    }
                });
            });
        });

        // Financials
        const COLORS = ['#ef4444', '#f59e0b', '#22c55e', '#3b82f6', '#8b5cf6', '#ec4899'];

        function fmt$(n) {
            if (n >= 1e9) return '$' + (n/1e9).toFixed(1) + 'B';
            if (n >= 1e6) return '$' + (n/1e6).toFixed(1) + 'M';
            if (n >= 1e3) return '$' + (n/1e3).toFixed(0) + 'K';
            return '$' + n.toFixed(0);
        }

        let scenarioData = null;
        let currentCharts = [];

        function destroyCharts() {
            currentCharts.forEach(c => c.destroy());
            currentCharts = [];
        }

        function renderFinancials(scenarios, scope) {
            if (!scenarios || scenarios.length === 0) {
                document.getElementById('headlines').innerHTML = '<div class="no-data">No scenario data found.</div>';
                document.getElementById('charts').innerHTML = '';
                return;
            }

            destroyCharts();

            // Update annotation
            const annotation = document.getElementById('scope-annotation');
            if (scope === 'city' && scenarioData.summary && scenarioData.summary.city_pct) {
                const pct = (scenarioData.summary.city_pct * 100).toFixed(0);
                annotation.textContent = 'City roads: ' + pct + '% of total pavement area';
                annotation.classList.add('visible');
            } else {
                annotation.classList.remove('visible');
            }

            // Find baseline (do-nothing)
            const baseline = scenarios.find(s => s.scenario.strategy === 0 || s.scenario.name === 'do-nothing' || s.scenario.name === 'baseline');
            if (!baseline) return;

            const lastYear = baseline.years[baseline.years.length - 1];
            const totalDoNothingCost = baseline.years.reduce((s, y) => s + y.annual_need, 0);

            // Find full-funding scenario
            const fullFunding = scenarios.find(s => s.scenario.name === 'fund-100pct');
            const fullFundingCost = fullFunding ? fullFunding.years.reduce((s, y) => s + y.annual_spend, 0) : 0;
            const costMultiplier = fullFundingCost > 0 ? (totalDoNothingCost / fullFundingCost).toFixed(1) : 'N/A';

            // Headlines
            document.getElementById('headlines').innerHTML = `
                <div class="headline-card">
                    <div class="label">Year 1 Treatment Need</div>
                    <div class="value">${fmt$(baseline.years[0].annual_need)}</div>
                    <div class="sub">Annual cost to maintain current condition</div>
                </div>
                <div class="headline-card">
                    <div class="label">${baseline.years.length}-Year Do-Nothing Backlog</div>
                    <div class="value">${fmt$(lastYear.deferred_backlog)}</div>
                    <div class="sub">Cumulative deferred maintenance</div>
                </div>
                <div class="headline-card">
                    <div class="label">End PCI (Do Nothing)</div>
                    <div class="value">${lastYear.pci.toFixed(0)}</div>
                    <div class="sub">Projected condition after ${baseline.years.length} years</div>
                </div>
                <div class="headline-card">
                    <div class="label">Cost Multiplier of Neglect</div>
                    <div class="value">${costMultiplier}x</div>
                    <div class="sub">Do-nothing total vs proactive maintenance</div>
                </div>
            `;

            // Charts
            const chartsDiv = document.getElementById('charts');
            chartsDiv.innerHTML = '';

            // Get funding-level scenarios
            const fundingScenarios = scenarios.filter(s =>
                ['baseline', 'fund-25pct', 'fund-50pct', 'fund-100pct'].includes(s.scenario.name)
            );

            // 1. PCI over time
            if (fundingScenarios.length > 0) {
                const card = makeChartCard('PCI Over Time by Funding Level');
                chartsDiv.appendChild(card);
                const ctx = card.querySelector('canvas').getContext('2d');
                currentCharts.push(new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: fundingScenarios[0].years.map(y => 'Year ' + y.year),
                        datasets: fundingScenarios.map((s, i) => ({
                            label: s.scenario.label,
                            data: s.years.map(y => y.pci),
                            borderColor: COLORS[i % COLORS.length],
                            backgroundColor: 'transparent',
                            tension: 0.3,
                            pointRadius: 0
                        }))
                    },
                    options: { responsive: true, scales: { y: { min: 0, max: 100, title: { display: true, text: 'PCI' } } }, plugins: { legend: { position: 'bottom' } } }
                }));
            }

            // 2. Deferred backlog growth
            if (fundingScenarios.length > 0) {
                const card = makeChartCard('Deferred Maintenance Backlog');
                chartsDiv.appendChild(card);
                const ctx = card.querySelector('canvas').getContext('2d');
                currentCharts.push(new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: fundingScenarios[0].years.map(y => 'Year ' + y.year),
                        datasets: fundingScenarios.map((s, i) => ({
                            label: s.scenario.label,
                            data: s.years.map(y => y.deferred_backlog),
                            borderColor: COLORS[i % COLORS.length],
                            backgroundColor: COLORS[i % COLORS.length] + '20',
                            fill: s.scenario.name === 'baseline',
                            tension: 0.3,
                            pointRadius: 0
                        }))
                    },
                    options: { responsive: true, scales: { y: { title: { display: true, text: 'Dollars ($)' }, ticks: { callback: v => fmt$(v) } } }, plugins: { legend: { position: 'bottom' } } }
                }));
            }

            // 3. Cumulative cost (exclude baseline)
            const fundedScenarios = fundingScenarios.filter(s => s.scenario.name !== 'baseline');
            if (fundedScenarios.length > 0) {
                const card = makeChartCard('Cumulative Spending');
                chartsDiv.appendChild(card);
                const ctx = card.querySelector('canvas').getContext('2d');
                currentCharts.push(new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: fundedScenarios[0].years.map(y => 'Year ' + y.year),
                        datasets: fundedScenarios.map((s, i) => {
                            let cum = 0;
                            return {
                                label: s.scenario.label,
                                data: s.years.map(y => { cum += y.annual_spend; return cum; }),
                                borderColor: COLORS[(i + 1) % COLORS.length],
                                backgroundColor: 'transparent',
                                tension: 0.3,
                                pointRadius: 0
                            };
                        })
                    },
                    options: { responsive: true, scales: { y: { title: { display: true, text: 'Dollars ($)' }, ticks: { callback: v => fmt$(v) } } }, plugins: { legend: { position: 'bottom' } } }
                }));
            }

            // 4. Strategy comparison
            const strategyScenarios = scenarios.filter(s =>
                ['worst-first-50', 'preventive-first-50'].includes(s.scenario.name)
            );
            if (strategyScenarios.length > 0) {
                const card = makeChartCard('Strategy Comparison: PCI at 50% Budget');
                chartsDiv.appendChild(card);
                const ctx = card.querySelector('canvas').getContext('2d');
                currentCharts.push(new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: strategyScenarios[0].years.map(y => 'Year ' + y.year),
                        datasets: strategyScenarios.map((s, i) => ({
                            label: s.scenario.label,
                            data: s.years.map(y => y.pci),
                            borderColor: COLORS[i + 3],
                            backgroundColor: 'transparent',
                            tension: 0.3,
                            pointRadius: 0
                        }))
                    },
                    options: { responsive: true, scales: { y: { min: 0, max: 100, title: { display: true, text: 'PCI' } } }, plugins: { legend: { position: 'bottom' } } }
                }));
            }

            // 5. Annual cost by tier (baseline)
            if (baseline) {
                const card = makeChartCard('Annual Treatment Need by Condition Tier');
                chartsDiv.appendChild(card);
                const ctx = card.querySelector('canvas').getContext('2d');
                const tierColors = { preventive: '#22c55e', rehab: '#f59e0b', reconstruction: '#ef4444' };
                const bgColors = baseline.years.map(y => tierColors[y.cost_tier] || '#9ca3af');
                currentCharts.push(new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: baseline.years.map(y => 'Year ' + y.year),
                        datasets: [{
                            label: 'Annual Need',
                            data: baseline.years.map(y => y.annual_need),
                            backgroundColor: bgColors
                        }]
                    },
                    options: {
                        responsive: true,
                        scales: { y: { title: { display: true, text: 'Dollars ($)' }, ticks: { callback: v => fmt$(v) } } },
                        plugins: {
                            legend: {
                                display: true,
                                position: 'bottom',
                                labels: {
                                    generateLabels: function() {
                                        return [
                                            { text: 'Preventive', fillStyle: '#22c55e', strokeStyle: '#22c55e' },
                                            { text: 'Rehab', fillStyle: '#f59e0b', strokeStyle: '#f59e0b' },
                                            { text: 'Reconstruction', fillStyle: '#ef4444', strokeStyle: '#ef4444' }
                                        ];
                                    }
                                }
                            }
                        }
                    }
                }));
            }
        }

        async function loadFinancials() {
            try {
                const resp = await fetch('data/scenarios.json');
                if (!resp.ok) throw new Error('not found');
                scenarioData = await resp.json();
            } catch(e) {
                document.getElementById('headlines').innerHTML = '<div class="no-data">No financial data available. Run <code>pvmt forecast</code> and <code>pvmt export</code> first.</div>';
                return;
            }

            // Handle both old (array) and new (object with all/city keys) formats
            let scenarios;
            if (Array.isArray(scenarioData)) {
                scenarios = scenarioData;
                scenarioData = { all: scenarios };
            } else {
                scenarios = scenarioData.all;
                if (scenarioData.city) {
                    document.getElementById('scope-toggle').style.display = 'flex';
                }
            }

            if (!scenarios || scenarios.length === 0) {
                document.getElementById('headlines').innerHTML = '<div class="no-data">No scenario data found.</div>';
                return;
            }

            renderFinancials(scenarios, 'all');
        }

        // Scope toggle handler
        document.querySelectorAll('#scope-toggle button').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('#scope-toggle button').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                const scope = btn.dataset.scope;
                const scenarios = scenarioData[scope] || scenarioData.all;
                renderFinancials(scenarios, scope);
            });
        });

        function makeChartCard(title) {
            const div = document.createElement('div');
            div.className = 'chart-card';
            div.innerHTML = '<h3>' + title + '</h3><canvas></canvas>';
            return div;
        }

        loadFinancials();
    </script>
</body>
</html>
