    <div id="config-tab" class="tab-content" role="tabpanel" aria-labelledby="config-tab-btn">
        <div class="config-tab">
            <h2>Project Configuration</h2>
            {{if .RawTOML}}
            <h3>Input Configuration</h3>
            <pre><code>{{.RawTOML}}</code></pre>
            {{end}}
            <h3>Effective configuration (with defaults)</h3>
            <pre><code>{{.ResolvedTOML}}</code></pre>
