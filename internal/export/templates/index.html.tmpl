                        <label for="pci-slider">Initial PCI: <span class="control-value" id="pci-value">85</span></label>
                        <input type="range" id="pci-slider" min="50" max="100" value="85" step="1" aria-valuemin="50" aria-valuemax="100" aria-valuenow="85">
