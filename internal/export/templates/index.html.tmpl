<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>PVMT - {{.ProjectName}}</title>
    <link rel="stylesheet" href="https://unpkg.com/maplibre-gl@4.1.2/dist/maplibre-gl.css">
    <script src="https://unpkg.com/maplibre-gl@4.1.2/dist/maplibre-gl.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
        #map { width: 100%; height: 100%; }
        .tab-bar {
            display: flex;
            background: #1a1a2e;
            padding: 0 16px;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            height: 48px;
        }
        .tab-bar h1 { color: #fff; font-size: 16px; line-height: 48px; margin-right: 32px; }
        .tab-btn {
            background: none;
            border: none;
            color: #8888aa;
            font-size: 14px;
            padding: 0 16px;
            cursor: pointer;
            line-height: 48px;
            border-bottom: 2px solid transparent;
        }
        .tab-btn.active { color: #fff; border-bottom-color: #3b82f6; }
        .tab-content { display: none; position: absolute; top: 48px; left: 0; right: 0; bottom: 0; z-index: 1; }
        .tab-content.active { display: block; }
        #map-tab { overflow: hidden; }
        #panel {
            position: absolute;
            top: 10px;
            right: 10px;
            background: rgba(255, 255, 255, 0.95);
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.15);
            max-width: 360px;
            font-size: 14px;
            z-index: 1;
            max-height: calc(100% - 20px);
            overflow-y: auto;
        }
        #panel h2 { font-size: 18px; margin-bottom: 4px; }
        #panel .subtitle { color: #666; margin-bottom: 16px; font-size: 12px; }
        .stat-card { background: #f9fafb; border-radius: 6px; padding: 12px; margin-bottom: 8px; }
        .stat-card h3 { font-size: 14px; text-transform: capitalize; margin-bottom: 8px; }
        .stat-row { display: flex; justify-content: space-between; padding: 2px 0; }
        .stat-label { color: #666; font-size: 13px; }
        .stat-value { font-weight: 600; font-size: 13px; }
        .layer-toggle { margin-top: 12px; border-top: 1px solid #eee; padding-top: 12px; }
        .layer-toggle label { display: flex; align-items: center; gap: 8px; cursor: pointer; padding: 4px 0; font-size: 13px; }
        .legend-dot { width: 12px; height: 12px; border-radius: 2px; display: inline-block; }
        .legend-gradient { width: 100px; height: 12px; border-radius: 2px; display: inline-block; }

        /* Color legend */
        #legend {
            position: absolute;
            bottom: 24px;
            right: 10px;
            background: rgba(255,255,255,0.92);
            padding: 10px 14px;
            border-radius: 6px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.15);
            z-index: 2;
            font-size: 12px;
        }
        #legend .legend-title { font-weight: 600; margin-bottom: 4px; }
        #legend .legend-bar {
            width: 180px; height: 12px; border-radius: 3px;
            background: linear-gradient(90deg, #f7fbff, #c6dbef, #6baed6, #2171b5, #08519c, #08306b);
        }
        #legend .legend-labels { display: flex; justify-content: space-between; margin-top: 2px; color: #666; }

        /* Hex tooltip */
        #hex-tooltip {
            position: absolute;
            pointer-events: none;
            z-index: 10;
            background: rgba(26,26,46,0.92);
            color: #fff;
            padding: 8px 12px;
            border-radius: 6px;
            font-size: 13px;
            line-height: 1.5;
            display: none;
            white-space: nowrap;
        }

        /* Hex detail panel */
        .hex-detail { font-size: 13px; }
        .hex-detail h3 { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
        .hex-detail .close-btn {
            background: none; border: none; font-size: 18px; cursor: pointer; color: #666; padding: 0 4px; line-height: 1;
        }
        .hex-detail table { width: 100%; border-collapse: collapse; }
        .hex-detail th, .hex-detail td { text-align: left; padding: 4px 6px; border-bottom: 1px solid #eee; }
        .hex-detail th { color: #666; font-weight: 500; }
        .hex-detail .total-row { font-weight: 600; border-top: 2px solid #ccc; }

        /* Financials tab */
        .financials { padding: 24px; max-width: 1200px; margin: 0 auto; overflow-y: auto; height: 100%; }
        .jurisdiction-toggle {
            display: flex;
            gap: 8px;
            margin-bottom: 20px;
        }
        .jurisdiction-toggle button {
            padding: 8px 20px;
            border: 1px solid #e5e7eb;
            border-radius: 6px;
            background: #fff;
            cursor: pointer;
            font-size: 14px;
            color: #666;
            transition: all 0.15s;
        }
        .jurisdiction-toggle button.active {
            background: #1a1a2e;
            color: #fff;
            border-color: #1a1a2e;
        }
        .scope-annotation {
            font-size: 13px;
            color: #666;
            margin-bottom: 16px;
            display: none;
        }
        .scope-annotation.visible { display: block; }
        .headlines { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; margin-bottom: 32px; }
        .headline-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 20px;
        }
        .headline-card .label { font-size: 13px; color: #666; margin-bottom: 4px; }
        .headline-card .value { font-size: 28px; font-weight: 700; color: #1a1a2e; }
        .headline-card .sub { font-size: 12px; color: #999; margin-top: 4px; }
        .chart-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(500px, 1fr)); gap: 24px; }
        .chart-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 20px;
        }
        .chart-card h3 { font-size: 15px; margin-bottom: 12px; color: #333; }
        .chart-card canvas { width: 100% !important; }
        .no-data { text-align: center; padding: 60px; color: #999; }

        /* Cohort breakdown */
        .cohort-section { margin-bottom: 32px; }
        .cohort-section > h3 { font-size: 15px; margin-bottom: 12px; color: #333; }
        .cohort-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; font-size: 14px; }
        .cohort-table th { text-align: left; padding: 8px 12px; border-bottom: 2px solid #e5e7eb; color: #666; font-weight: 600; cursor: pointer; user-select: none; }
        .cohort-table th:hover { color: #333; }
        .cohort-table th .sort-arrow { font-size: 11px; margin-left: 4px; color: #999; }
        .cohort-table td { padding: 8px 12px; border-bottom: 1px solid #f3f4f6; }
        .cohort-table tr:hover { background: #f9fafb; }
        .cohort-table .total-row { font-weight: 600; border-top: 2px solid #ccc; }
        .cohort-table .total-row td { border-bottom: none; }
        .cohort-table td.number { text-align: right; }
        .cohort-table th.number { text-align: right; }
        .pci-badge {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 4px;
            font-weight: 600;
            font-size: 13px;
        }
        .pci-good { background: #dcfce7; color: #166534; }
        .pci-fair { background: #fef3c7; color: #92400e; }
        .pci-poor { background: #fee2e2; color: #991b1b; }

        /* Interactive forecast controls */
        .forecast-controls {
            background: #f9fafb;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 24px;
            display: none;
        }
        .forecast-controls.visible { display: block; }
        .forecast-controls h3 { font-size: 15px; margin-bottom: 16px; color: #333; }
        .controls-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 16px;
        }
        .control-group { display: flex; flex-direction: column; gap: 4px; }
        .control-group label { font-size: 13px; color: #666; font-weight: 500; }
        .control-group .control-value { font-size: 13px; color: #1a1a2e; font-weight: 600; }
        .control-group input[type="range"] {
            width: 100%;
            accent-color: #3b82f6;
        }
        .strategy-buttons {
            display: flex;
            gap: 6px;
        }
        .strategy-buttons button {
            padding: 6px 14px;
            border: 1px solid #e5e7eb;
            border-radius: 6px;
            background: #fff;
            cursor: pointer;
            font-size: 13px;
            color: #666;
            transition: all 0.15s;
        }
        .strategy-buttons button.active {
            background: #1a1a2e;
            color: #fff;
            border-color: #1a1a2e;
        }
        .advanced-toggle {
            background: none;
            border: none;
            color: #3b82f6;
            font-size: 13px;
            cursor: pointer;
            padding: 4px 0;
            margin-top: 12px;
        }
        .advanced-controls {
            display: none;
            margin-top: 16px;
            border-top: 1px solid #e5e7eb;
            padding-top: 16px;
        }
        .advanced-controls.visible { display: block; }
        .tier-row {
            display: grid;
            grid-template-columns: 1fr 80px 80px 100px;
            gap: 8px;
            align-items: center;
            margin-bottom: 8px;
            font-size: 13px;
        }
        .tier-row.header { font-weight: 600; color: #666; }
        .tier-row input {
            width: 100%;
            padding: 4px 6px;
            border: 1px solid #e5e7eb;
            border-radius: 4px;
            font-size: 13px;
        }
    </style>
</head>
<body>
    <div class="tab-bar">
        <h1>PVMT</h1>
        <button class="tab-btn active" data-tab="map-tab">Map</button>
        <button class="tab-btn" data-tab="financials-tab">Financials</button>
    </div>

    <div id="map-tab" class="tab-content active">
        <div id="map"></div>
        <div id="panel">
            <h2>{{.ProjectName}}</h2>
            <div class="subtitle">Pavement & Parking Analysis | {{.SnapshotDate}}</div>
            <div id="stats">
            {{range .Stats}}
                <div class="stat-card">
                    <h3>{{.Type}}</h3>
                    <div class="stat-row">
                        <span class="stat-label">Features</span>
                        <span class="stat-value" id="count-{{.Type}}">{{.FeatureCount}}</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">Area (acres)</span>
                        <span class="stat-value">{{printf "%.1f" .TotalAreaAcres}}</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">Area (sq mi)</span>
                        <span class="stat-value">{{printf "%.2f" (divf .TotalAreaAcres 640)}}</span>
                    </div>
                </div>
            {{end}}
            </div>
            <div class="layer-toggle" id="toggles"></div>
        </div>
        <div id="legend">
            <div class="legend-title">Coverage %</div>
            <div class="legend-bar"></div>
            <div class="legend-labels">
                <span>0%</span><span>25%</span><span>50%</span><span>75%</span><span>100%</span>
            </div>
        </div>
        <div id="hex-tooltip"></div>
    </div>

    <div id="financials-tab" class="tab-content">
        <div class="financials">
            <div class="jurisdiction-toggle" id="scope-toggle" style="display:none">
                <button class="active" data-scope="all">All Roads</button>
                <button data-scope="city">City Roads Only</button>
            </div>
            <div class="scope-annotation" id="scope-annotation"></div>
            <div class="headlines" id="headlines" style="display:none">
                <div class="headline-card">
                    <div class="label">Blended End PCI</div>
                    <div class="value" id="hl-end-pci">—</div>
                    <div class="sub">Area-weighted condition after forecast</div>
                </div>
                <div class="headline-card">
                    <div class="label">20-Year Spend</div>
                    <div class="value" id="hl-total-spend">—</div>
                    <div class="sub">Total budget allocated</div>
                </div>
                <div class="headline-card">
                    <div class="label">20-Year Deficit</div>
                    <div class="value" id="hl-total-deficit">—</div>
                    <div class="sub">Accumulated unfunded need</div>
                </div>
            </div>

            <div class="forecast-controls" id="forecast-controls">
                <h3>Interactive Forecast</h3>
                <div class="controls-grid">
                    <div class="control-group">
                        <label>Budget Level: <span class="control-value" id="budget-value">50%</span></label>
                        <input type="range" id="budget-slider" min="0" max="150" value="50" step="5">
                    </div>
                    <div class="control-group">
                        <label>Initial PCI: <span class="control-value" id="pci-value">85</span></label>
                        <input type="range" id="pci-slider" min="50" max="100" value="85" step="1">
                    </div>
                    <div class="control-group">
                        <label>Strategy</label>
                        <div class="strategy-buttons" id="strategy-buttons">
                            <button class="active" data-strategy="worst-first">Worst First</button>
                            <button data-strategy="preventive-first">Preventive First</button>
                        </div>
                    </div>
                </div>
                <button class="advanced-toggle" id="advanced-toggle">Advanced options</button>
                <div class="advanced-controls" id="advanced-controls">
                    <div class="tier-row header">
                        <span>Tier</span>
                        <span>Min PCI</span>
                        <span>Max PCI</span>
                        <span>$/sq ft</span>
                    </div>
                    <div id="tier-inputs"></div>
                </div>
            </div>

            <div class="cohort-section" id="cohort-section" style="display:none">
                <h3>Road Classification Breakdown</h3>
                <table class="cohort-table" id="cohort-table">
                    <thead><tr>
                        <th>Classification</th>
                        <th class="number">Area (acres)</th>
                        <th class="number">Area %</th>
                        <th class="number">Decay Rate</th>
                        <th class="number">End PCI</th>
                        <th class="number">20yr Spend</th>
                        <th class="number">20yr Deficit</th>
                    </tr></thead>
                    <tbody></tbody>
                </table>
            </div>

            <div class="chart-grid" id="charts"></div>
        </div>
    </div>

    <script>
        // Tab switching
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
                btn.classList.add('active');
                document.getElementById(btn.dataset.tab).classList.add('active');
                if (btn.dataset.tab === 'map-tab' && window._map) window._map.resize();
            });
        });

        // Map
        const CENTER = [{{.CenterLon}}, {{.CenterLat}}];
        const layerColors = { {{range .Stats}}'{{.Type}}': '{{.Color}}', {{end}} };

        const map = new maplibregl.Map({
            container: 'map',
            style: {
                version: 8,
                sources: { 'osm': { type: 'raster', tiles: ['https://tile.openstreetmap.org/{z}/{x}/{y}.png'], tileSize: 256, attribution: '&copy; OpenStreetMap' } },
                layers: [{ id: 'osm', type: 'raster', source: 'osm', minzoom: 0, maxzoom: 19 }]
            },
            center: CENTER,
            zoom: 13
        });
        window._map = map;

        // Hex interactivity state
        let hexDataByType = {};   // { roads: [...features], parking: [...features] }
        let costSummary = {};     // { roads: {year1_cost, total_area_sqft}, ... }
        let activeTypes = new Set(Object.keys(layerColors));
        let savedPanelHTML = '';

        function fmtNum(n) {
            return Math.round(n).toLocaleString();
        }

        function fmtCost(n) {
            if (n >= 1e6) return '$' + (n/1e6).toFixed(1) + 'M';
            if (n >= 1e3) return '$' + (n/1e3).toFixed(0) + 'K';
            return '$' + Math.round(n).toLocaleString();
        }

        // Build blended hex FeatureCollection from active types
        function buildBlendedHexFC(hexDataByType, activeTypes, costSummary) {
            // Group all features by hex_id, only from active types
            const byHex = {};
            for (const type of activeTypes) {
                const features = hexDataByType[type] || [];
                for (const f of features) {
                    const hid = f.properties.hex_id;
                    if (!byHex[hid]) {
                        byHex[hid] = { geometry: f.geometry, area_sqft: 0, pct_covered: 0, est_cost: 0 };
                    }
                    byHex[hid].area_sqft += f.properties.area_sqft || 0;
                    byHex[hid].pct_covered += f.properties.pct_covered || 0;
                }
            }

            // Compute est_cost per hex
            for (const type of activeTypes) {
                const cs = costSummary[type];
                if (!cs || !cs.total_area_sqft) continue;
                const features = hexDataByType[type] || [];
                for (const f of features) {
                    const hid = f.properties.hex_id;
                    if (!byHex[hid]) continue;
                    byHex[hid].est_cost += ((f.properties.area_sqft || 0) / cs.total_area_sqft) * cs.year1_cost;
                }
            }

            const features = [];
            for (const [hid, data] of Object.entries(byHex)) {
                features.push({
                    type: 'Feature',
                    geometry: data.geometry,
                    properties: {
                        hex_id: hid,
                        area_sqft: data.area_sqft,
                        pct_covered: Math.min(data.pct_covered, 100),
                        est_cost: data.est_cost
                    }
                });
            }
            return { type: 'FeatureCollection', features };
        }

        function updateHexGrid() {
            const src = map.getSource('hexgrid');
            if (!src) return;
            const fc = buildBlendedHexFC(hexDataByType, activeTypes, costSummary);
            src.setData(fc);
        }

        map.on('load', async () => {
            let toggles = '';

            // Load resource layers
            for (const type of Object.keys(layerColors)) {
                try {
                    const resp = await fetch('data/' + type + '.geojson');
                    if (!resp.ok) continue;
                    const data = await resp.json();
                    map.addSource(type, { type: 'geojson', data });
                    map.addLayer({
                        id: type + '-fill', type: 'fill', source: type,
                        paint: { 'fill-color': layerColors[type], 'fill-opacity': 0.4, 'fill-outline-color': layerColors[type] }
                    });
                    toggles += '<label><input type="checkbox" checked data-layers="' + type + '-fill" data-type="' + type + '"><span class="legend-dot" style="background:' + layerColors[type] + '"></span>' + type + '</label>';
                } catch(e) {}
            }

            // Load hex cost summary
            try {
                const resp = await fetch('data/hex-cost-summary.json');
                if (resp.ok) costSummary = await resp.json();
            } catch(e) {}

            // Load hex grid
            try {
                const resp = await fetch('data/hexgrid.geojson');
                if (resp.ok) {
                    const data = await resp.json();
                    if (data.features && data.features.length > 0) {
                        // Parse into per-type buckets
                        for (const f of data.features) {
                            const rt = f.properties.resource_type || 'unknown';
                            if (!hexDataByType[rt]) hexDataByType[rt] = [];
                            hexDataByType[rt].push(f);
                        }

                        // Build initial blended FC
                        const blended = buildBlendedHexFC(hexDataByType, activeTypes, costSummary);

                        map.addSource('hexgrid', { type: 'geojson', data: blended });
                        map.addLayer({
                            id: 'hex-fill', type: 'fill', source: 'hexgrid',
                            paint: {
                                'fill-color': ['interpolate', ['linear'], ['get', 'pct_covered'],
                                    0, '#f7fbff', 10, '#c6dbef', 25, '#6baed6', 50, '#2171b5', 75, '#08519c', 100, '#08306b'],
                                'fill-opacity': 0.6
                            }
                        });
                        map.addLayer({
                            id: 'hex-outline', type: 'line', source: 'hexgrid',
                            paint: { 'line-color': '#333', 'line-width': 0.5, 'line-opacity': 0.3 }
                        });
                        toggles += '<label><input type="checkbox" checked data-layers="hex-fill,hex-outline"><span class="legend-gradient" style="background:linear-gradient(90deg,#c6dbef,#08306b)"></span>hex grid</label>';

                        // Hover tooltip
                        const tooltip = document.getElementById('hex-tooltip');
                        map.on('mousemove', 'hex-fill', e => {
                            map.getCanvas().style.cursor = 'pointer';
                            if (e.features && e.features.length > 0) {
                                const p = e.features[0].properties;
                                tooltip.innerHTML =
                                    '<strong>Coverage:</strong> ' + (p.pct_covered != null ? Math.round(p.pct_covered) : 0) + '%<br>' +
                                    '<strong>Area:</strong> ' + fmtNum(p.area_sqft || 0) + ' sq ft<br>' +
                                    '<strong>Est. Cost:</strong> ' + fmtCost(p.est_cost || 0);
                                tooltip.style.display = 'block';
                                tooltip.style.left = (e.point.x + 12) + 'px';
                                tooltip.style.top = (e.point.y - 12) + 'px';
                            }
                        });
                        map.on('mouseleave', 'hex-fill', () => {
                            map.getCanvas().style.cursor = '';
                            tooltip.style.display = 'none';
                        });

                        // Click detail panel
                        map.on('click', 'hex-fill', e => {
                            if (!e.features || e.features.length === 0) return;
                            const p = e.features[0].properties;
                            const hexId = p.hex_id;

                            // Save current stats panel
                            const statsEl = document.getElementById('stats');
                            if (!statsEl.querySelector('.hex-detail')) {
                                savedPanelHTML = statsEl.innerHTML;
                            }

                            // Build per-type breakdown
                            let rows = '';
                            let totalArea = 0, totalPct = 0, totalCost = 0;
                            for (const type of Object.keys(layerColors)) {
                                const features = hexDataByType[type] || [];
                                const match = features.find(f => f.properties.hex_id === hexId);
                                if (!match) continue;
                                const area = match.properties.area_sqft || 0;
                                const pct = match.properties.pct_covered || 0;
                                let cost = 0;
                                const cs = costSummary[type];
                                if (cs && cs.total_area_sqft) {
                                    cost = (area / cs.total_area_sqft) * cs.year1_cost;
                                }
                                totalArea += area;
                                totalPct += pct;
                                totalCost += cost;
                                rows += '<tr><td style="text-transform:capitalize">' + type + '</td><td>' + fmtNum(area) + '</td><td>' + Math.round(pct) + '%</td><td>' + fmtCost(cost) + '</td></tr>';
                            }

                            statsEl.innerHTML =
                                '<div class="hex-detail">' +
                                '<h3>Hex ' + hexId + '<button class="close-btn" id="close-hex">&times;</button></h3>' +
                                '<table><tr><th>Type</th><th>Area (sqft)</th><th>Coverage</th><th>Est. Cost</th></tr>' +
                                rows +
                                '<tr class="total-row"><td>Total</td><td>' + fmtNum(totalArea) + '</td><td>' + Math.min(Math.round(totalPct), 100) + '%</td><td>' + fmtCost(totalCost) + '</td></tr>' +
                                '</table></div>';

                            document.getElementById('close-hex').addEventListener('click', () => {
                                statsEl.innerHTML = savedPanelHTML;
                            });
                        });
                    }
                }
            } catch(e) {}

            document.getElementById('toggles').innerHTML = toggles;
            document.querySelectorAll('#toggles input').forEach(cb => {
                cb.addEventListener('change', e => {
                    const vis = e.target.checked ? 'visible' : 'none';
                    e.target.dataset.layers.split(',').forEach(id => map.setLayoutProperty(id, 'visibility', vis));

                    // Update activeTypes and reblend hex grid
                    const type = e.target.dataset.type;
                    if (type) {
                        if (e.target.checked) {
                            activeTypes.add(type);
                        } else {
                            activeTypes.delete(type);
                        }
                        updateHexGrid();
                    }
                });
            });
        });

        // Financials
        const COLORS = ['#ef4444', '#f59e0b', '#22c55e', '#3b82f6', '#8b5cf6', '#ec4899'];

        function fmt$(n) {
            if (n >= 1e9) return '$' + (n/1e9).toFixed(1) + 'B';
            if (n >= 1e6) return '$' + (n/1e6).toFixed(1) + 'M';
            if (n >= 1e3) return '$' + (n/1e3).toFixed(0) + 'K';
            return '$' + n.toFixed(0);
        }

        let scenarioData = null;
        let currentCharts = [];

        function destroyCharts() {
            currentCharts.forEach(c => c.destroy());
            currentCharts = [];
        }

        function renderFinancials(scenarios, scope) {
            if (!scenarios || scenarios.length === 0) {
                document.getElementById('charts').innerHTML = '';
                return;
            }

            destroyCharts();

            // Update annotation
            const annotation = document.getElementById('scope-annotation');
            if (scope === 'city' && scenarioData.summary && scenarioData.summary.city_pct) {
                const pct = (scenarioData.summary.city_pct * 100).toFixed(0);
                annotation.textContent = 'City roads: ' + pct + '% of total pavement area';
                annotation.classList.add('visible');
            } else {
                annotation.classList.remove('visible');
            }

            // Find baseline (do-nothing)
            const baseline = scenarios.find(s => s.scenario.strategy === 0 || s.scenario.name === 'do-nothing' || s.scenario.name === 'baseline');
            if (!baseline) return;

            // Charts
            const chartsDiv = document.getElementById('charts');
            chartsDiv.innerHTML = '';

            // Get funding-level scenarios
            const fundingScenarios = scenarios.filter(s =>
                ['baseline', 'fund-25pct', 'fund-50pct', 'fund-100pct'].includes(s.scenario.name)
            );

            // 1. PCI over time
            if (fundingScenarios.length > 0) {
                const card = makeChartCard('PCI Over Time by Funding Level');
                chartsDiv.appendChild(card);
                const ctx = card.querySelector('canvas').getContext('2d');
                currentCharts.push(new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: fundingScenarios[0].years.map(y => 'Year ' + y.year),
                        datasets: fundingScenarios.map((s, i) => ({
                            label: s.scenario.label,
                            data: s.years.map(y => y.pci),
                            borderColor: COLORS[i % COLORS.length],
                            backgroundColor: 'transparent',
                            tension: 0.3,
                            pointRadius: 0
                        }))
                    },
                    options: { responsive: true, scales: { y: { min: 0, max: 100, title: { display: true, text: 'PCI' } } }, plugins: { legend: { position: 'bottom' } } }
                }));
            }

            // 2. Deferred backlog growth
            if (fundingScenarios.length > 0) {
                const card = makeChartCard('Deferred Maintenance Backlog');
                chartsDiv.appendChild(card);
                const ctx = card.querySelector('canvas').getContext('2d');
                currentCharts.push(new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: fundingScenarios[0].years.map(y => 'Year ' + y.year),
                        datasets: fundingScenarios.map((s, i) => ({
                            label: s.scenario.label,
                            data: s.years.map(y => y.deferred_backlog),
                            borderColor: COLORS[i % COLORS.length],
                            backgroundColor: COLORS[i % COLORS.length] + '20',
                            fill: s.scenario.name === 'baseline',
                            tension: 0.3,
                            pointRadius: 0
                        }))
                    },
                    options: { responsive: true, scales: { y: { title: { display: true, text: 'Dollars ($)' }, ticks: { callback: v => fmt$(v) } } }, plugins: { legend: { position: 'bottom' } } }
                }));
            }

            // 3. Cumulative cost (exclude baseline)
            const fundedScenarios = fundingScenarios.filter(s => s.scenario.name !== 'baseline');
            if (fundedScenarios.length > 0) {
                const card = makeChartCard('Cumulative Spending');
                chartsDiv.appendChild(card);
                const ctx = card.querySelector('canvas').getContext('2d');
                currentCharts.push(new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: fundedScenarios[0].years.map(y => 'Year ' + y.year),
                        datasets: fundedScenarios.map((s, i) => {
                            let cum = 0;
                            return {
                                label: s.scenario.label,
                                data: s.years.map(y => { cum += y.annual_spend; return cum; }),
                                borderColor: COLORS[(i + 1) % COLORS.length],
                                backgroundColor: 'transparent',
                                tension: 0.3,
                                pointRadius: 0
                            };
                        })
                    },
                    options: { responsive: true, scales: { y: { title: { display: true, text: 'Dollars ($)' }, ticks: { callback: v => fmt$(v) } } }, plugins: { legend: { position: 'bottom' } } }
                }));
            }

            // 4. Annual cost by tier (baseline)
            if (baseline) {
                const card = makeChartCard('Annual Treatment Need by Condition Tier');
                chartsDiv.appendChild(card);
                const ctx = card.querySelector('canvas').getContext('2d');
                const tierColors = { preventive: '#22c55e', rehab: '#f59e0b', reconstruction: '#ef4444' };
                const bgColors = baseline.years.map(y => tierColors[y.cost_tier] || '#9ca3af');
                currentCharts.push(new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: baseline.years.map(y => 'Year ' + y.year),
                        datasets: [{
                            label: 'Annual Need',
                            data: baseline.years.map(y => y.annual_need),
                            backgroundColor: bgColors
                        }]
                    },
                    options: {
                        responsive: true,
                        scales: { y: { title: { display: true, text: 'Dollars ($)' }, ticks: { callback: v => fmt$(v) } } },
                        plugins: {
                            legend: {
                                display: true,
                                position: 'bottom',
                                labels: {
                                    generateLabels: function() {
                                        return [
                                            { text: 'Preventive', fillStyle: '#22c55e', strokeStyle: '#22c55e' },
                                            { text: 'Rehab', fillStyle: '#f59e0b', strokeStyle: '#f59e0b' },
                                            { text: 'Reconstruction', fillStyle: '#ef4444', strokeStyle: '#ef4444' }
                                        ];
                                    }
                                }
                            }
                        }
                    }
                }));
            }
        }

        var forecastData = null;
        var lastCohorts = null;
        var cohortSortCol = 1; // default: area descending
        var cohortSortAsc = false;

        // Column definitions for sorting: [key, type]
        var cohortColumns = [
            ['classification', 'string'],
            ['area_sqft', 'number'],
            ['area_pct', 'number'],
            ['decay_rate', 'number'],
            ['end_pci', 'number'],
            ['total_spend', 'number'],
            ['total_deficit', 'number']
        ];

        function renderCohortBreakdown(cohorts, keepSort) {
            lastCohorts = cohorts;
            const totalArea = cohorts.reduce((s, c) => s + c.area_sqft, 0);

            // Enrich with computed fields for sorting
            const enriched = cohorts.map(c => ({
                ...c,
                area_pct: totalArea > 0 ? c.area_sqft / totalArea * 100 : 0,
                total_spend: c.total_spend || 0,
                total_deficit: c.total_deficit || 0
            }));

            // Sort
            if (!keepSort) { cohortSortCol = 1; cohortSortAsc = false; }
            const key = cohortColumns[cohortSortCol][0];
            const isStr = cohortColumns[cohortSortCol][1] === 'string';
            const sorted = [...enriched].sort((a, b) => {
                const av = a[key], bv = b[key];
                const cmp = isStr ? String(av).localeCompare(String(bv)) : av - bv;
                return cohortSortAsc ? cmp : -cmp;
            });

            function fmtCurrency(v) {
                return '$' + v.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
            }

            // Update header sort arrows
            document.querySelectorAll('#cohort-table thead th').forEach((th, i) => {
                var arrow = th.querySelector('.sort-arrow');
                if (!arrow) { arrow = document.createElement('span'); arrow.className = 'sort-arrow'; th.appendChild(arrow); }
                arrow.textContent = i === cohortSortCol ? (cohortSortAsc ? '\u25B2' : '\u25BC') : '';
            });

            const tbody = document.querySelector('#cohort-table tbody');
            tbody.innerHTML = '';
            let totalSpend = 0;
            let totalDeficit = 0;

            sorted.forEach(c => {
                const acres = c.area_sqft / 43560;
                const pci = c.end_pci;
                let cls = 'pci-good';
                if (pci < 40) cls = 'pci-poor';
                else if (pci < 60) cls = 'pci-fair';

                totalSpend += c.total_spend;
                totalDeficit += c.total_deficit;

                const tr = document.createElement('tr');
                tr.innerHTML =
                    '<td style="text-transform:capitalize">' + c.classification + '</td>' +
                    '<td class="number">' + acres.toFixed(1) + '</td>' +
                    '<td class="number">' + c.area_pct.toFixed(1) + '%</td>' +
                    '<td class="number">' + c.decay_rate.toFixed(4) + '</td>' +
                    '<td class="number"><span class="pci-badge ' + cls + '">' + pci.toFixed(0) + '</span></td>' +
                    '<td class="number">' + fmtCurrency(c.total_spend) + '</td>' +
                    '<td class="number">' + fmtCurrency(c.total_deficit) + '</td>';
                tbody.appendChild(tr);
            });

            // Totals row
            const totalAcres = totalArea / 43560;
            const totTr = document.createElement('tr');
            totTr.className = 'total-row';
            totTr.innerHTML =
                '<td>Total</td>' +
                '<td class="number">' + totalAcres.toFixed(1) + '</td>' +
                '<td class="number">100%</td>' +
                '<td></td><td></td>' +
                '<td class="number">' + fmtCurrency(totalSpend) + '</td>' +
                '<td class="number">' + fmtCurrency(totalDeficit) + '</td>';
            tbody.appendChild(totTr);

            document.getElementById('cohort-section').style.display = 'block';
        }

        // Bind sort click handlers
        document.querySelectorAll('#cohort-table thead th').forEach((th, i) => {
            th.addEventListener('click', () => {
                if (!lastCohorts) return;
                if (cohortSortCol === i) {
                    cohortSortAsc = !cohortSortAsc;
                } else {
                    cohortSortCol = i;
                    cohortSortAsc = cohortColumns[i][1] === 'string'; // strings default asc, numbers desc
                }
                renderCohortBreakdown(lastCohorts, true);
            });
        });

        async function loadFinancials() {
            try {
                const resp = await fetch('data/scenarios.json');
                if (!resp.ok) throw new Error('not found');
                scenarioData = await resp.json();
            } catch(e) {
                document.getElementById('charts').innerHTML = '<div class="no-data">No financial data available. Run <code>pvmt forecast</code> and <code>pvmt export</code> first.</div>';
                return;
            }

            // Handle both old (array) and new (object with all/city keys) formats
            let scenarios;
            if (Array.isArray(scenarioData)) {
                scenarios = scenarioData;
                scenarioData = { all: scenarios };
            } else {
                scenarios = scenarioData.all;
                if (scenarioData.city) {
                    document.getElementById('scope-toggle').style.display = 'flex';
                }
            }

            if (!scenarios || scenarios.length === 0) {
                document.getElementById('charts').innerHTML = '<div class="no-data">No scenario data found.</div>';
                return;
            }

            renderFinancials(scenarios, 'all');

            // Fetch forecast.json (used by scope toggle for static fallback)
            try {
                const fResp = await fetch('data/forecast.json');
                if (fResp.ok) {
                    forecastData = await fResp.json();
                }
            } catch(e) { /* forecast data optional */ }
        }

        // Scope toggle handler
        document.querySelectorAll('#scope-toggle button').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('#scope-toggle button').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                const scope = btn.dataset.scope;
                const scenarios = scenarioData[scope] || scenarioData.all;
                renderFinancials(scenarios, scope);
                if (wasmReady) {
                    runCustomScenario();
                } else if (forecastData) {
                    const roads = forecastData.find(f => f.resource_type === 'roads');
                    const src = (scope === 'city' && roads && roads.city_baseline) ? roads.city_baseline : (roads && roads.baseline);
                    if (src && src.final_cohorts && src.final_cohorts.length > 1) {
                        renderCohortBreakdown(src.final_cohorts);
                    } else {
                        document.getElementById('cohort-section').style.display = 'none';
                    }
                }
            });
        });

        function makeChartCard(title) {
            const div = document.createElement('div');
            div.className = 'chart-card';
            div.innerHTML = '<h3>' + title + '</h3><canvas></canvas>';
            return div;
        }

        loadFinancials();

        // WASM forecast seed & interactive controls
        const FORECAST_SEED = {{.ForecastSeed}};

        let wasmReady = false;
        let chartRefs = { pci: null, backlog: null, spending: null };
        let customActive = false;
        let currentStrategy = 'worst-first';

        function onWasmReady() {
            wasmReady = true;
            document.getElementById('forecast-controls').classList.add('visible');
            // Run initial simulation to populate cohort table
            runCustomScenario();
            // Populate tier inputs from seed
            const tierDiv = document.getElementById('tier-inputs');
            tierDiv.innerHTML = '';
            (FORECAST_SEED.cost_tiers || []).forEach((t, i) => {
                const row = document.createElement('div');
                row.className = 'tier-row';
                row.innerHTML =
                    '<span>' + (t.label || 'Tier ' + (i+1)) + '</span>' +
                    '<input type="number" data-tier="' + i + '" data-field="min_pci" value="' + t.min_pci + '" step="1">' +
                    '<input type="number" data-tier="' + i + '" data-field="max_pci" value="' + t.max_pci + '" step="1">' +
                    '<input type="number" data-tier="' + i + '" data-field="cost_per_sqft" value="' + t.cost_per_sqft + '" step="0.01">';
                tierDiv.appendChild(row);
            });
            // Bind tier input events
            tierDiv.querySelectorAll('input').forEach(inp => {
                inp.addEventListener('input', runCustomScenario);
            });
        }

        function getControlValues() {
            const budgetPct = parseInt(document.getElementById('budget-slider').value) / 100;
            const initialPCI = parseInt(document.getElementById('pci-slider').value);

            // Read tier values from inputs (advanced), fallback to seed
            const tiers = (FORECAST_SEED.cost_tiers || []).map((t, i) => {
                const minInput = document.querySelector('[data-tier="' + i + '"][data-field="min_pci"]');
                const maxInput = document.querySelector('[data-tier="' + i + '"][data-field="max_pci"]');
                const costInput = document.querySelector('[data-tier="' + i + '"][data-field="cost_per_sqft"]');
                return {
                    min_pci: minInput ? parseFloat(minInput.value) : t.min_pci,
                    max_pci: maxInput ? parseFloat(maxInput.value) : t.max_pci,
                    cost_per_sqft: costInput ? parseFloat(costInput.value) : t.cost_per_sqft,
                    label: t.label
                };
            });

            // Determine area and cohorts from current scope
            const activeScope = document.querySelector('#scope-toggle button.active');
            const scope = activeScope ? activeScope.dataset.scope : 'all';
            const area = (scope === 'city' && FORECAST_SEED.city_area_sqft > 0)
                ? FORECAST_SEED.city_area_sqft
                : FORECAST_SEED.total_area_sqft;
            const seedCohorts = (scope === 'city' && FORECAST_SEED.city_cohorts && FORECAST_SEED.city_cohorts.length > 0)
                ? FORECAST_SEED.city_cohorts
                : (FORECAST_SEED.cohorts || []);

            // Compute baseline year-1 need to derive budget
            const baselineInput = {
                area_sqft: area,
                initial_pci: initialPCI,
                decay_rate: FORECAST_SEED.decay_rate,
                growth_rate: FORECAST_SEED.growth_rate,
                years: FORECAST_SEED.years,
                cost_tiers: tiers,
                annual_budget: 0,
                strategy: 'do-nothing',
                cohorts: seedCohorts
            };
            const baselineRaw = window.simulateForecast(JSON.stringify(baselineInput));
            const baseline = JSON.parse(baselineRaw);
            if (baseline.error) return null;

            const year1Need = baseline.years && baseline.years.length > 0 ? baseline.years[0].annual_need : 0;
            const annualBudget = budgetPct > 0 ? year1Need * budgetPct : 0;

            return {
                area_sqft: area,
                initial_pci: initialPCI,
                decay_rate: FORECAST_SEED.decay_rate,
                growth_rate: FORECAST_SEED.growth_rate,
                years: FORECAST_SEED.years,
                cost_tiers: tiers,
                annual_budget: annualBudget,
                strategy: currentStrategy,
                cohorts: seedCohorts
            };
        }

        function runCustomScenario() {
            if (!wasmReady) return;
            const input = getControlValues();
            if (!input) return;

            const raw = window.simulateForecast(JSON.stringify(input));
            const result = JSON.parse(raw);
            if (result.error) return;

            customActive = true;
            updateCustomScenario(result);
            updateSummaryCards(result);

            // Update cohort breakdown from WASM result
            if (result.final_cohorts && result.final_cohorts.length > 1) {
                renderCohortBreakdown(result.final_cohorts);
            } else {
                document.getElementById('cohort-section').style.display = 'none';
            }
        }

        function updateSummaryCards(result) {
            const years = result.years || [];
            const lastPCI = years.length > 0 ? years[years.length - 1].pci : 0;
            const totalSpend = years.reduce((s, y) => s + y.annual_spend, 0);
            const totalDeficit = years.length > 0 ? years[years.length - 1].deferred_backlog : 0;

            document.getElementById('hl-end-pci').textContent = lastPCI.toFixed(0);
            document.getElementById('hl-total-spend').textContent = fmt$(totalSpend);
            document.getElementById('hl-total-deficit').textContent = fmt$(totalDeficit);
            document.getElementById('headlines').style.display = '';
        }

        function updateCustomScenario(result) {
            const customColor = '#10b981';
            const years = result.years || [];

            // Update PCI chart
            if (chartRefs.pci) {
                updateChartDataset(chartRefs.pci, 'Custom Scenario', years.map(y => y.pci), customColor);
            }
            // Update backlog chart
            if (chartRefs.backlog) {
                updateChartDataset(chartRefs.backlog, 'Custom Scenario', years.map(y => y.deferred_backlog), customColor);
            }
            // Update spending chart
            if (chartRefs.spending) {
                let cum = 0;
                const cumData = years.map(y => { cum += y.annual_spend; return cum; });
                updateChartDataset(chartRefs.spending, 'Custom Scenario', cumData, customColor);
            }
            // Update tier chart
            if (chartRefs.tier) {
                const tierColors = { preventive: '#22c55e', rehab: '#f59e0b', reconstruction: '#ef4444' };
                const idx = chartRefs.tier.data.datasets.findIndex(ds => ds.label === 'Custom Need');
                const ds = {
                    label: 'Custom Need',
                    data: years.map(y => y.annual_need),
                    backgroundColor: years.map(y => (tierColors[y.cost_tier] || '#9ca3af') + '80'),
                    borderColor: customColor,
                    borderWidth: 1
                };
                if (idx >= 0) {
                    chartRefs.tier.data.datasets[idx] = ds;
                } else {
                    chartRefs.tier.data.datasets.push(ds);
                }
                chartRefs.tier.update('none');
            }
        }

        function updateChartDataset(chart, label, data, color) {
            const idx = chart.data.datasets.findIndex(ds => ds.label === label);
            const ds = {
                label: label,
                data: data,
                borderColor: color,
                backgroundColor: 'transparent',
                borderDash: [6, 3],
                tension: 0.3,
                pointRadius: 0
            };
            if (idx >= 0) {
                chart.data.datasets[idx] = ds;
            } else {
                chart.data.datasets.push(ds);
            }
            chart.update('none');
        }

        // Override renderFinancials to capture chart refs
        const _origRenderFinancials = renderFinancials;
        renderFinancials = function(scenarios, scope) {
            chartRefs = { pci: null, backlog: null, spending: null, tier: null };
            _origRenderFinancials(scenarios, scope);

            // Capture chart refs from currentCharts (order: pci, backlog, spending, tier)
            if (currentCharts.length >= 1) chartRefs.pci = currentCharts[0];
            if (currentCharts.length >= 2) chartRefs.backlog = currentCharts[1];
            if (currentCharts.length >= 3) chartRefs.spending = currentCharts[2];
            if (currentCharts.length >= 4) chartRefs.tier = currentCharts[3];

            // Re-apply custom scenario if active
            if (customActive && wasmReady) {
                runCustomScenario();
            }
        };

        // Control event bindings
        document.getElementById('budget-slider').addEventListener('input', e => {
            document.getElementById('budget-value').textContent = e.target.value + '%';
            runCustomScenario();
        });
        document.getElementById('pci-slider').addEventListener('input', e => {
            document.getElementById('pci-value').textContent = e.target.value;
            runCustomScenario();
        });
        document.querySelectorAll('#strategy-buttons button').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('#strategy-buttons button').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                currentStrategy = btn.dataset.strategy;
                runCustomScenario();
            });
        });
        document.getElementById('advanced-toggle').addEventListener('click', () => {
            const adv = document.getElementById('advanced-controls');
            adv.classList.toggle('visible');
            document.getElementById('advanced-toggle').textContent =
                adv.classList.contains('visible') ? 'Hide advanced options' : 'Advanced options';
        });

        // Load WASM
        if (typeof WebAssembly !== 'undefined') {
            const script = document.createElement('script');
            script.src = 'wasm_exec.js';
            script.onload = function() {
                const go = new Go();
                WebAssembly.instantiateStreaming(fetch('forecast.wasm'), go.importObject)
                    .then(result => { go.run(result.instance); onWasmReady(); })
                    .catch(err => console.warn('WASM load failed:', err));
            };
            document.head.appendChild(script);
        }
    </script>
</body>
</html>
